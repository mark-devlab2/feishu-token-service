<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Feishu Token Service</title>
    <style>
      body { font-family: sans-serif; margin: 24px; }
      table { border-collapse: collapse; width: 100%; margin-bottom: 24px; }
      th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
      th { background: #f5f5f5; }
    </style>
  </head>
  <body>
    <h1>Feishu Token Service Admin</h1>

    <h2>Tokens</h2>
    <table>
      <thead>
        <tr>
          <th>User</th>
          <th>Status</th>
          <th>Scopes</th>
          <th>Expires At</th>
        </tr>
      </thead>
      <tbody>
        {{#each tokens}}
          <tr>
            <td><a href="/admin/tokens/{{this.user.openId}}">{{this.user.openId}}</a></td>
            <td>{{this.status}}</td>
            <td>{{this.scopes}}</td>
            <td>{{this.expiresAt}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>

    <h2>Recent Events</h2>
    <table>
      <thead>
        <tr><th>Type</th><th>Message</th><th>Created</th></tr>
      </thead>
      <tbody>
        {{#each events}}
          <tr><td>{{this.type}}</td><td>{{this.message}}</td><td>{{this.createdAt}}</td></tr>
        {{/each}}
      </tbody>
    </table>

    <h2>Alerts</h2>
    <table>
      <thead>
        <tr><th>Level</th><th>Status</th><th>Kind</th><th>Message</th><th>Created</th></tr>
      </thead>
      <tbody>
        {{#each alerts}}
          <tr><td>{{this.level}}</td><td>{{this.status}}</td><td>{{this.kind}}</td><td>{{this.message}}</td><td>{{this.createdAt}}</td></tr>
        {{/each}}
      </tbody>
    </table>
  </body>
  </html>
