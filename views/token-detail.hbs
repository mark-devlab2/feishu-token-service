<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Token Detail</title>
    <style>
      body { font-family: sans-serif; margin: 24px; }
      pre { background: #f6f6f6; padding: 12px; overflow: auto; }
    </style>
  </head>
  <body>
    <h1>Token Detail</h1>
    {{#if token}}
      <p>User: <strong>{{token.user.openId}}</strong></p>
      <p>Status: <strong>{{token.status}}</strong></p>
      <p>Expires: <strong>{{token.expiresAt}}</strong></p>
      <p>Scopes: <strong>{{token.scopes}}</strong></p>

      <h2>Events</h2>
      <ul>
        {{#each events}}
          <li>{{this.createdAt}} - {{this.type}} - {{this.message}}</li>
        {{/each}}
      </ul>

      <h2>Alerts</h2>
      <ul>
        {{#each alerts}}
          <li>{{this.createdAt}} - {{this.level}} - {{this.kind}} - {{this.message}}</li>
        {{/each}}
      </ul>
    {{else}}
      <p>Token not found.</p>
    {{/if}}
  </body>
  </html>
