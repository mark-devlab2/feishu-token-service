NODE_ENV=production
PORT=3080
API_PUBLISH=127.0.0.1:3080:3080
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/feishu_token_service?schema=public
REDIS_URL=redis://redis:6379
TOKEN_ENCRYPTION_KEY=replace_with_32_byte_secret
INTERNAL_API_KEY=replace_with_internal_api_key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_admin_password
ADMIN_SESSION_TTL_HOURS=24
ADMIN_SHELL_URL=https://admin.himark.me/auth-center
ADMIN_WEB_ORIGINS=https://admin.himark.me
DEFAULT_SUPER_ADMIN_USERNAME=mark
DEFAULT_SUPER_ADMIN_DISPLAY_NAME=Mark
BOOTSTRAP_FEISHU_OWNER_OPEN_ID=
BOOTSTRAP_FEISHU_OWNER_DISPLAY_NAME=
FEISHU_APP_AUTH_ACCOUNT_KEY=openclaw-main
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=replace_with_feishu_app_secret
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_REDIRECT_URI=https://token.himark.me/auth/feishu/callback
FEISHU_SCOPES=offline_access,contact:user.base:readonly,im:chat:readonly,im:message:readonly,search:message,task:task:read,task:task:write,im:message.p2p_msg:get_as_user,im:message.group_msg:get_as_user,docx:document:readonly,docs:document.content:read,drive:drive:readonly,space:document:retrieve,wiki:node:read,wiki:wiki:readonly,minutes:minutes:readonly,minutes:minutes.basic:read
ALERT_WEBHOOK_URL=
REFRESH_LOOKAHEAD_SECONDS=900
LOCK_TTL_SECONDS=120
