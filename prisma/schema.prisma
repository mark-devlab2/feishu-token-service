generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProviderType {
  FEISHU
}

enum UserStatus {
  active
  disabled
}

enum AuthorizationKind {
  personal
  app
}

enum AuthorizationStatus {
  active
  expiring
  expired
  refreshing
  reauthorization_required
  revoked
}

enum AuthEventType {
  auth_link_created
  auth_callback_succeeded
  auth_callback_failed
  refresh_succeeded
  refresh_failed
  invalidated
  enabled
  disabled
  token_invalidated
  token_deleted
  personal_authorization_enabled
  personal_authorization_disabled
}

enum AlertLevel {
  P1
  P2
}

enum AlertStatus {
  open
  acknowledged
  resolved
}

enum AdminAccountStatus {
  active
  disabled
}

model User {
  id                     String                  @id @default(cuid())
  username               String                  @unique
  displayName            String?
  status                 UserStatus              @default(active)
  isSuperAdmin           Boolean                 @default(false)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  platformAccounts       PlatformAccount[]
  platformAuthorizations PlatformAuthorization[]
}

model Provider {
  id                     String                  @id @default(cuid())
  type                   ProviderType            @unique
  displayName            String
  enabled                Boolean                 @default(true)
  config                 Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  platformAccounts       PlatformAccount[]
  platformAuthorizations PlatformAuthorization[]
  authSessions           AuthSession[]
}

model PlatformAccount {
  id                     String                  @id @default(cuid())
  providerId             String
  userId                 String
  externalSubjectId      String
  displayName            String?
  enabled                Boolean                 @default(true)
  metadata               Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  provider               Provider                @relation(fields: [providerId], references: [id])
  user                   User                    @relation(fields: [userId], references: [id])
  platformAuthorizations PlatformAuthorization[]

  @@unique([providerId, externalSubjectId])
  @@index([userId, providerId])
}

model PlatformAuthorization {
  id                    String                @id @default(cuid())
  providerId            String
  authKind              AuthorizationKind     @default(personal)
  userId                String?
  platformAccountId     String?
  accountKey            String                @default("")
  enabled               Boolean               @default(false)
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  scopes                String[]
  expiresAt             DateTime?
  refreshExpiresAt      DateTime?
  status                AuthorizationStatus   @default(expired)
  lastRefreshAt         DateTime?
  lastFailureAt         DateTime?
  failureReason         String?
  metadata              Json?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  provider              Provider              @relation(fields: [providerId], references: [id])
  user                  User?                 @relation(fields: [userId], references: [id])
  platformAccount       PlatformAccount?      @relation(fields: [platformAccountId], references: [id])
  authEvents            AuthEvent[]
  alerts                Alert[]

  @@unique([providerId, authKind, accountKey])
  @@index([providerId, authKind, userId])
  @@index([status, expiresAt])
}

model AdminAccount {
  id           String             @id @default(cuid())
  username     String             @unique
  passwordHash String
  status       AdminAccountStatus @default(active)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  sessions     AdminSession[]
}

model AdminSession {
  id             String       @id @default(cuid())
  adminAccountId String
  tokenHash      String       @unique
  expiresAt      DateTime
  lastSeenAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  adminAccount   AdminAccount @relation(fields: [adminAccountId], references: [id], onDelete: Cascade)

  @@index([adminAccountId, expiresAt])
}

model AuthEvent {
  id                    String                @id @default(cuid())
  platformAuthorizationId String
  type                  AuthEventType
  message               String
  metadata              Json?
  createdAt             DateTime              @default(now())
  platformAuthorization PlatformAuthorization @relation(fields: [platformAuthorizationId], references: [id])

  @@index([platformAuthorizationId, createdAt])
}

model AuthSession {
  id                String   @id @default(cuid())
  providerId        String
  userId            String?
  platformAccountId String?
  requestSubjectId  String
  state             String   @unique
  codeVerifier      String?
  returnContext     String?
  status            String   @default("pending")
  expiresAt         DateTime
  createdAt         DateTime @default(now())
  completedAt       DateTime?
  provider          Provider @relation(fields: [providerId], references: [id])

  @@index([providerId, requestSubjectId, status])
}

model Alert {
  id                    String                 @id @default(cuid())
  platformAuthorizationId String?
  level                 AlertLevel
  status                AlertStatus            @default(open)
  kind                  String
  message               String
  createdAt             DateTime               @default(now())
  resolvedAt            DateTime?
  platformAuthorization PlatformAuthorization? @relation(fields: [platformAuthorizationId], references: [id])

  @@index([status, createdAt])
}
